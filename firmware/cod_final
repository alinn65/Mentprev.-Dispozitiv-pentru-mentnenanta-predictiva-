  if (webNavShort) { webNavShort = false; return true; }   // apoi flag-ul web (consumat o data)
  return phys;
}
bool navLong() {
  bool phys = clickLong(navBtn, NAV_LONG_MS);
  if (webNavLong) { webNavLong = false; return true; }
  return phys;
}

// =====================================================
// PCF8563 - FUNCTII
// Cipul stocheaza timpul in format BCD (fiecare cifra zecimala pe 4 biti),
// deci convertim inainte/dupa fiecare citire/scriere.
// =====================================================
static inline uint8_t bcdToDecPcf(uint8_t bcd) { return ((bcd >> 4) * 10) + (bcd & 0x0F); } // BCD -> zecimal
static inline uint8_t decToBcdPcf(uint8_t dec)  { return ((dec / 10) << 4) | (dec % 10); }   // zecimal -> BCD

// Initializeaza RTC-ul: verifica prezenta pe I2C si reseteaza registrele de control
bool initRTC() {
  Wire.beginTransmission(PCF8563_ADDR);
  if (Wire.endTransmission() != 0) return false;   // nu raspunde -> nu exista RTC
  Wire.beginTransmission(PCF8563_ADDR);
  Wire.write(PCF8563_REG_STATUS1);
  Wire.write(0x00);                                // control 1 = normal
  Wire.write(0x00);                                // control 2 = fara intreruperi
  Wire.endTransmission();
  return true;
}

// Citeste data si ora din RTC in structura data
bool rtcRead(RtcTime& t) {
  Wire.beginTransmission(PCF8563_ADDR);
  Wire.write(PCF8563_REG_VL_SEC);                  // pornim de la registrul de secunde
  if (Wire.endTransmission(false) != 0) return false; // repeated start, fara stop
  Wire.requestFrom((uint8_t)PCF8563_ADDR, (uint8_t)7); // citim 7 registre consecutive
  if (Wire.available() < 7) return false;
  uint8_t sec_r = Wire.read(), min_r = Wire.read(), hour_r = Wire.read(), day_r = Wire.read();
  Wire.read();                                     // weekday - ignorat (il recalculam la scriere)
  uint8_t mon_r = Wire.read(), year_r = Wire.read();
  // Mascam bitii de stare/rezerva inainte de conversie (fiecare registru are biti utili specifici)
  t.sec   = bcdToDecPcf(sec_r   & 0x7F);
  t.min   = bcdToDecPcf(min_r   & 0x7F);
  t.hour  = bcdToDecPcf(hour_r  & 0x3F);
  t.day   = bcdToDecPcf(day_r   & 0x3F);
  t.month = bcdToDecPcf(mon_r   & 0x1F);
  t.year  = bcdToDecPcf(year_r);
  return true;
}

// Scrie data si ora in RTC; recalculeaza ziua saptamanii cu algoritmul lui Zeller
bool rtcWrite(const RtcTime& t) {
  int d = t.day, m = t.month, y = 2000 + t.year;
  if (m < 3) { m += 12; y--; }                     // ian/feb tratate ca lunile 13/14 ale anului precedent
  int k = y % 100, j = y / 100;
  int dow = ((d + (13*(m+1)/5) + k + k/4 + j/4 + 5*j) % 7 + 6) % 7; // ziua saptamanii (0=luni)
  Wire.beginTransmission(PCF8563_ADDR);
  Wire.write(PCF8563_REG_VL_SEC);
  Wire.write(decToBcdPcf(t.sec)   & 0x7F);
  Wire.write(decToBcdPcf(t.min)   & 0x7F);
  Wire.write(decToBcdPcf(t.hour)  & 0x3F);
  Wire.write(decToBcdPcf(t.day)   & 0x3F);
  Wire.write(dow                  & 0x07);
  Wire.write(decToBcdPcf(t.month) & 0x1F);
  Wire.write(decToBcdPcf(t.year));
  return (Wire.endTransmission() == 0);
}

// Reimprospateaza cache-ul de ora periodic (nu la fiecare cadru, ci o data pe secunda)
void updateRtcCache() {
  if (!rtcAvailable) return;
  if (millis() - lastRtcRead >= RTC_READ_INTERVAL_MS) {
    // protejam accesul I2C cu mutex (accelerometrul foloseste aceeasi magistrala)
    if (i2cMutex == nullptr || xSemaphoreTake(i2cMutex, pdMS_TO_TICKS(5)) == pdTRUE) {
      rtcRead(rtcCache);
      if (i2cMutex != nullptr) xSemaphoreGive(i2cMutex);
    }
    lastRtcRead = millis();
  }
}

// Formateaza data ca text "AAAA-LL-ZZ" pentru log
void rtcDateString(char* buf, size_t n) {
  if (rtcAvailable)
    snprintf(buf, n, "20%02d-%02d-%02d", rtcCache.year, rtcCache.month, rtcCache.day);
  else
    snprintf(buf, n, "0000-00-00");                // RTC absent -> data nula
}
// Formateaza ora ca text "HH:MM:SS" pentru log
void rtcTimeString(char* buf, size_t n) {
  if (rtcAvailable)
    snprintf(buf, n, "%02d:%02d:%02d", rtcCache.hour, rtcCache.min, rtcCache.sec);
  else
    snprintf(buf, n, "00:00:00");
}

