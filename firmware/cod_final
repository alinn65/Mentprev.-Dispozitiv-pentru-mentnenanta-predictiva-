// =====================================================
// ECRAN EROARE INIT - afisat daca un periferic esential lipseste
// =====================================================
void drawInitErrorScreen(bool okDisplay, bool okAccel, bool okSD, bool okI2S, bool okMutex) {
  if (!okDisplay) {
    // Daca tocmai ecranul a esuat, nu avem unde desena -> raportam doar pe Serial
    Serial.println("=== INIT ERROR ===");
    Serial.printf("DISPLAY : %s\n", okDisplay ? "OK" : "FAIL");
    Serial.printf("ACCEL   : %s\n", okAccel   ? "OK" : "FAIL");
    Serial.printf("SD CARD : %s\n", okSD      ? "OK" : "FAIL");
    Serial.printf("I2S MIC : %s\n", okI2S     ? "OK" : "FAIL");
    Serial.printf("MUTEX   : %s\n", okMutex   ? "OK" : "FAIL");
    return;
  }
  sprite.fillSprite(BG_COLOR);
  sprite.setTextColor(TFT_RED);
  sprite.drawString("INIT ERROR", SCREEN_CX, 28, 2);
  sprite.drawFastHLine(35, 42, 170, sprite.color565(60, 0, 0));

  // Tabel cu starea fiecarui periferic
  struct { const char* name; bool ok; } components[5] = {
    {"DISPLAY", okDisplay}, {"ACCEL", okAccel}, {"SD CARD", okSD},
    {"I2S MIC", okI2S},     {"MUTEX",  okMutex}
  };
  const int startY = 62, stepY = 26;
  for (int i = 0; i < 5; i++) {
    int yC = startY + i * stepY;
    bool ok = components[i].ok;
    if (!ok) sprite.fillRoundRect(32, yC - 10, 176, 20, 4, sprite.color565(50, 0, 0)); // fundal rosu pe esec
    sprite.setTextDatum(ML_DATUM);
    sprite.setTextColor(ok ? sprite.color565(150,150,150) : TFT_WHITE);
    sprite.drawString(components[i].name, 40, yC, 2);
    sprite.setTextDatum(MR_DATUM);
    sprite.setTextColor(ok ? TFT_GREEN : TFT_RED);
    sprite.drawString(ok ? "OK" : "FAIL", 200, yC, 2);
  }
  sprite.setTextDatum(MC_DATUM);
  sprite.drawFastHLine(35, 198, 170, sprite.color565(40,40,40));
  sprite.setTextColor(sprite.color565(80,80,80));
  sprite.drawString("CHECK WIRING", SCREEN_CX, 212, 1);
  drawCircularClipBorder(sprite.color565(60,0,0));
  sprite.pushSprite(0, 0);

  Serial.println("=== INIT ERROR ===");
  for (int i = 0; i < 5; i++)
    Serial.printf("%-10s: %s\n", components[i].name, components[i].ok ? "OK" : "FAIL");
}

// =====================================================
// LOOP MAIN - bucla principala, ruleaza pe core 1
// Trateaza interfata si masina de stari; sarcinile grele (FFT) sunt pe core 0.
// =====================================================
void loop() {
  updateRtcCache();             // reimprospateaza ora periodic
  updateWifiLed();              // gestioneaza LED-ul de status WiFi
  updateStatusLed();            // LED de stare masina (doar in monitoring)
  if (wifiStarted) webServer.handleClient();   // serveste cererile web

  // ---- MAIN MENU ----
  if (state == MAIN_MENU) {
    // PWR scurt = navigheaza inapoi prin meniul circular
    if (clickShort(pwrBtn, NAV_LONG_MS)) {
      if (--logicalMenuPosition < 0) { logicalMenuPosition += MENU_COUNT; currentAngle += 360.0f; }
      selectedOption = (MenuOption)logicalMenuPosition;
    }
    // NAV scurt (fizic sau web) = navigheaza inainte
    if (navShort()) {
      if (++logicalMenuPosition >= MENU_COUNT) { logicalMenuPosition -= MENU_COUNT; currentAngle -= 360.0f; }
      selectedOption = (MenuOption)logicalMenuPosition;
    }
    // NAV lung (fizic sau web) = intra in optiunea selectata
    if (navLong()) {
      if (selectedOption == MENU_TEST) {
        playMenuTransitionOut();
        clearBuffers();
        if (machineCount > 0) {
          machineSelCursor = selectedMachine;
          state = SELECT_MACHINE;   // alege utilajul intai
        } else {
          // niciun utilaj definit -> mergem direct, nume generic
          prepareNextLogFile();
          state = WAIT_AMBIENT;
        }
      } else if (selectedOption == MENU_VIEW_DATA) {
        scanLogFiles();
        if (logFileCount == 0) {
          drawCenteredMessage("NICIUN FISIER", "CARDUL E GOL", TFT_RED);
          vTaskDelay(pdMS_TO_TICKS(1500));
        } else {
          playMenuTransitionOut();
          browserCursor = logFileCount - 1;  // pornim de la cel mai recent
          browserScroll = max(0, browserCursor - FILES_PER_PAGE + 1);
          state = FILE_BROWSER;
        }
      } else if (selectedOption == MENU_SETTINGS) {
        playMenuTransitionOut();
        settingsCursor = SET_ITEM_SAMPLING;
        state = SETTINGS_VIEW;
      } else if (selectedOption == MENU_SHUTDOWN) {
        doShutdown();             // oprire completa
      }
    }
    updateButton(pwrBtn);         // mentine starea butonului actualizata
    if (state == MAIN_MENU) drawMainMenu();
  }

  // ---- SETTINGS VIEW ----
  else if (state == SETTINGS_VIEW) {
    // PWR lung = inapoi la meniu
    if (clickLong(pwrBtn, PWR_LONG_BACK_MS)) { playMenuTransitionIn(false); state = MAIN_MENU; }
    // PWR scurt = schimba valoarea optiunii curente
    if (clickShort(pwrBtn, PWR_LONG_BACK_MS)) {
      if (settingsCursor == SET_ITEM_SAMPLING) {
        currentSamplingIndex = (currentSamplingIndex + 1) % 4;  // cicleaza duratele
      } else if (settingsCursor == SET_ITEM_WIFI) {
        wifiEnabled = !wifiEnabled;            // comuta WiFi
        if (wifiEnabled) wifiStart();
        else             wifiStop();
      }
    }
    // NAV scurt = muta cursorul intre optiuni
    if (clickShort(navBtn, NAV_LONG_MS)) {
      settingsCursor = (settingsCursor + 1) % SET_ITEM_COUNT;
    }
    // NAV lung = actiune (enter pe optiunea curenta)
    if (clickLong(navBtn, NAV_LONG_MS)) {
      if (settingsCursor == SET_ITEM_TIME) {
        if (rtcAvailable) {
          // pre-incarcam valorile curente in campurile de editare
          setTimeVals[SET_HOUR]  = rtcCache.hour;
          setTimeVals[SET_MIN]   = rtcCache.min;
          setTimeVals[SET_SEC]   = 0;
          setTimeVals[SET_DAY]   = rtcCache.day;
          setTimeVals[SET_MONTH] = rtcCache.month;
          setTimeVals[SET_YEAR]  = rtcCache.year;
          setTimeField = SET_HOUR;
          state = SETTINGS_SET_TIME;
        } else {
          drawCenteredMessage("RTC", "INDISPONIBIL", TFT_RED);
          vTaskDelay(pdMS_TO_TICKS(1200));
        }
      } else if (settingsCursor == SET_ITEM_WIFI) {
        wifiEnabled = !wifiEnabled;
        if (wifiEnabled) wifiStart();
        else             wifiStop();
      } else if (settingsCursor == SET_ITEM_SAMPLING) {
        currentSamplingIndex = (currentSamplingIndex + 1) % 4;
      }
    }
    updateButton(navBtn);
    updateButton(pwrBtn);
    if (state == SETTINGS_VIEW) drawSettingsView();
  }

  // ---- SETARE DATA/ORA ----
  else if (state == SETTINGS_SET_TIME) {
    // PWR scurt = incrementeaza campul curent (cu rollover specific fiecaruia)
    if (clickShort(pwrBtn, PWR_LONG_BACK_MS)) {
      switch (setTimeField) {
        case SET_HOUR:  setTimeVals[SET_HOUR]  = (setTimeVals[SET_HOUR]  + 1) % 24; break;
        case SET_MIN:   setTimeVals[SET_MIN]   = (setTimeVals[SET_MIN]   + 1) % 60; break;
        case SET_SEC:   setTimeVals[SET_SEC]   = (setTimeVals[SET_SEC]   + 1) % 60; break;
        case SET_DAY:   setTimeVals[SET_DAY]   = (setTimeVals[SET_DAY]  >= 31) ? 1 : setTimeVals[SET_DAY]   + 1; break;
        case SET_MONTH: setTimeVals[SET_MONTH] = (setTimeVals[SET_MONTH]>= 12) ? 1 : setTimeVals[SET_MONTH] + 1; break;
        case SET_YEAR:  setTimeVals[SET_YEAR]  = (setTimeVals[SET_YEAR]  + 1) % 100; break;
      }
    }
    if (clickLong(pwrBtn, PWR_LONG_BACK_MS)) state = SETTINGS_VIEW;  // PWR lung = renunta
    if (clickShort(navBtn, NAV_LONG_MS))     setTimeField = (setTimeField + 1) % SET_FIELD_COUNT; // NAV scurt = camp urmator
    // NAV lung = salveaza ora in RTC
    if (clickLong(navBtn, NAV_LONG_MS)) {
      RtcTime newTime = { setTimeVals[SET_SEC], setTimeVals[SET_MIN], setTimeVals[SET_HOUR],
                          setTimeVals[SET_DAY], setTimeVals[SET_MONTH], setTimeVals[SET_YEAR] };
      if (rtcWrite(newTime)) { rtcCache = newTime; drawCenteredMessage("SALVAT!", "ORA SETATA", TFT_GREEN); }
      else                     drawCenteredMessage("EROARE", "SCRIERE RTC", TFT_RED);
      vTaskDelay(pdMS_TO_TICKS(900));
      state = SETTINGS_VIEW;
    }
    updateButton(navBtn);
    updateButton(pwrBtn);
    if (state == SETTINGS_SET_TIME) drawSetTimeView();
  }

  // ---- SELECTIE UTILAJ (inainte de test) ----
  else if (state == SELECT_MACHINE) {
    // PWR lung = inapoi la meniu
    if (clickLong(pwrBtn, PWR_LONG_BACK_MS)) { playMenuTransitionIn(false); state = MAIN_MENU; return; }
    // NAV scurt (fizic sau web) = utilajul urmator
    if (navShort()) {
      machineSelCursor = (machineSelCursor + 1) % machineCount;
    }
    // PWR scurt = utilajul anterior
    if (clickShort(pwrBtn, PWR_LONG_BACK_MS)) {
      machineSelCursor = (machineSelCursor - 1 + machineCount) % machineCount;
    }
    // NAV lung (fizic sau web) = confirma utilajul si porneste testul
    if (navLong()) {
      selectedMachine = machineSelCursor;
      buildLogFileName();    // construieste numele cu utilaj + data + ora
      state = WAIT_AMBIENT;
    }
    updateButton(pwrBtn);
    if (state == SELECT_MACHINE) drawSelectMachine();
  }

  // ---- FILE BROWSER ----
  else if (state == FILE_BROWSER) {
    // PWR scurt = fisierul anterior (urca in lista)
    if (clickShort(pwrBtn, PWR_LONG_BACK_MS)) {
      if (browserCursor > 0) { browserCursor--; if (browserCursor < browserScroll) browserScroll = browserCursor; }
    }
    if (clickLong(pwrBtn, PWR_LONG_BACK_MS)) { playMenuTransitionIn(false); state = MAIN_MENU; } // PWR lung = meniu
    // NAV scurt = fisierul urmator (coboara in lista)
    if (clickShort(navBtn, NAV_LONG_MS)) {
      if (browserCursor < logFileCount - 1) {
        browserCursor++;
        if (browserCursor >= browserScroll + FILES_PER_PAGE) browserScroll = browserCursor - FILES_PER_PAGE + 1;
      }
    }
    // NAV lung = deschide graficul fisierului selectat
    if (clickLong(navBtn, NAV_LONG_MS)) {
      plotCursor = browserCursor;
      strncpy(currentLogFile, logFileList[plotCursor], sizeof(currentLogFile));
      state = PLOT_VIEW;
      drawPlotFromSD(currentLogFile);
    }
    if (state == FILE_BROWSER) drawFileBrowser();
  }

  // ---- WAIT AMBIENT (Step 1: calibrare zgomot de fond) ----
  else if (state == WAIT_AMBIENT) {
    if (clickLong(pwrBtn, PWR_LONG_BACK_MS)) { playMenuTransitionIn(false); state = MAIN_MENU; return; }
    // ecran de instructiune
    sprite.fillSprite(BG_COLOR);
    sprite.setTextColor(TFT_WHITE);
    sprite.drawString("STEP 1", SCREEN_CX, 60, 4);
    sprite.drawString("HALL CALIBRATION", SCREEN_CX, 90, 2);
    sprite.fillCircle(SCREEN_CX, 155, 30, TFT_CYAN);
    sprite.setTextColor(TFT_BLACK);
    sprite.drawString("PRESS", SCREEN_CX, 150, 2);
    sprite.setTextColor(TFT_DARKGREY);
    sprite.drawString("AUTO ORIENTATION", SCREEN_CX, 215, 2);
    drawCircularClipBorder(sprite.color565(25,25,25));
    sprite.pushSprite(0, 0);
    // NAV scurt (fizic sau web) = porneste calibrarea ambient (invata si orientarea)
    if (navShort()) {
      drawCenteredMessage("STEP 1", "HALL CALIBRATION", TFT_CYAN);
      if (runCalibration(ambientFFT, true, false)) state = WAIT_MACHINE;
      else { drawCenteredMessage("ERROR", "NO SENSOR DATA", TFT_RED); vTaskDelay(pdMS_TO_TICKS(1000)); }
    }
  }

  // ---- WAIT MACHINE (Step 2: invata semnatura masinii sanatoase) ----
  else if (state == WAIT_MACHINE) {
    if (clickLong(pwrBtn, PWR_LONG_BACK_MS)) { playMenuTransitionIn(false); clearBuffers(); state = MAIN_MENU; return; }
    sprite.fillSprite(BG_COLOR);
    sprite.setTextColor(TFT_WHITE);
    sprite.drawString("STEP 2", SCREEN_CX, 60, 4);
    sprite.drawString("ENGINE ANALYSIS", SCREEN_CX, 90, 2);
    sprite.fillCircle(SCREEN_CX, 155, 30, TFT_CYAN);
    sprite.setTextColor(TFT_BLACK);
    sprite.drawString("PRESS", SCREEN_CX, 150, 2);
    sprite.setTextColor(TFT_CYAN);
    sprite.drawString(mountModeToString(currentMode), SCREEN_CX, 215, 2);  // orientarea detectata
    drawCircularClipBorder(sprite.color565(25,25,25));
    sprite.pushSprite(0, 0);
    // NAV scurt (fizic sau web) = porneste calibrarea masinii
    if (navShort()) {
      drawCenteredMessage("STEP 2", "ENGINE ANALYSIS", TFT_CYAN);
      if (runCalibration(machineFFT, false, true)) {
        // scadem zgomotul ambiant din semnatura masinii (cu marja AMBIENT_MULTIPLIER)
        for (int i = 0; i < FFT_BINS; i++) {
          double clean = machineFFT[i] - (ambientFFT[i] * AMBIENT_MULTIPLIER);
          machineFFT[i] = (clean < 0.0) ? 0.0 : clean;
        }
        learnedPower  = computeCleanPower(machineFFT, 2, FFT_BINS, FFT_NOISE_GATE); // puterea de referinta
        healthScore   = 100.0f; anomalyScore = 0.0f; smoothVib = 0.0f; vibAlertLevel = 0.0f; // resetam scorurile
        memset(smoothedFFT, 0, sizeof(smoothedFFT));
        state = MONITORING;
      } else { drawCenteredMessage("ERROR", "NO SENSOR DATA", TFT_RED); vTaskDelay(pdMS_TO_TICKS(1000)); }
    }
  }

  // ---- MONITORING (rularea propriu-zisa) ----
  else if (state == MONITORING) {
    // PWR lung = iesire la meniu; reaprindem backlight si stingem LED-ul de stare
    if (clickLong(pwrBtn, PWR_LONG_BACK_MS)) { playMenuTransitionIn(false); clearBuffers(); backlightOn = true; digitalWrite(DISPLAY_PWR_PIN, LOW); digitalWrite(STATUS_LED_PIN, LOW); statusLedState = false; state = MAIN_MENU; return; }
    // PWR scurt = stinge/aprinde backlight-ul (monitorizarea continua in fundal)
    if (clickShort(pwrBtn, PWR_LONG_BACK_MS)) {
      backlightOn = !backlightOn;
      // pin 4 controleaza backlight: LOW = aprins (cum e folosit in cod), HIGH = stins
      digitalWrite(DISPLAY_PWR_PIN, backlightOn ? LOW : HIGH);
    }
    double    currentRaw[FFT_BINS];
    AccelData e;
    // luam un snapshot al datelor de la senzori si actualizam monitorizarea
    if (getSharedSnapshot(currentRaw, &e)) updateMonitoring(currentRaw, e);
    else drawCenteredMessage("WAITING...", "SENSOR DATA", TFT_YELLOW);
    updateButton(pwrBtn);
    // NAV scurt = sare la graficul ultimului fisier logat
    if (clickShort(navBtn, NAV_LONG_MS)) {
      scanLogFiles();
      plotCursor = logFileCount - 1;
      if (plotCursor >= 0) {
        strncpy(currentLogFile, logFileList[plotCursor], sizeof(currentLogFile));
        state = PLOT_VIEW;
        drawPlotFromSD(currentLogFile);
      }
    }
  }

  // ---- PLOT VIEW (vizualizare grafic health dintr-un fisier) ----
  else if (state == PLOT_VIEW) {
    bool needRedraw = false;
    // PWR scurt = fisierul anterior
    if (clickShort(pwrBtn, PWR_LONG_BACK_MS)) {
      if (plotCursor > 0) { plotCursor--; strncpy(currentLogFile, logFileList[plotCursor], sizeof(currentLogFile)); needRedraw = true; }
    }
    // PWR lung = inapoi la browserul de fisiere
    if (clickLong(pwrBtn, PWR_LONG_BACK_MS)) {
      browserCursor = plotCursor;
      browserScroll = max(0, browserCursor - FILES_PER_PAGE + 1);
      state = FILE_BROWSER;
    }
    // NAV scurt = fisierul urmator; daca era ultimul, iesim la meniu
    if (clickShort(navBtn, NAV_LONG_MS)) {
      if (plotCursor < logFileCount - 1) {
        plotCursor++;
        strncpy(currentLogFile, logFileList[plotCursor], sizeof(currentLogFile));
        needRedraw = true;
      } else { playMenuTransitionIn(false); state = MAIN_MENU; }
    }
    updateButton(navBtn);
    if (needRedraw && state == PLOT_VIEW) drawPlotFromSD(currentLogFile); // redesenam doar la schimbare
  }

  vTaskDelay(pdMS_TO_TICKS(16));  // ~60 cadre/s; cedeaza CPU ca sa nu infometam watchdog-ul
}

// =====================================================
// UTILITARE ECRAN ROTUND
// =====================================================
// Deseneaza marginea circulara (masca ecranul rotund)
void drawCircularClipBorder(uint16_t color) {
  sprite.drawSmoothCircle(SCREEN_CX, SCREEN_CY, SCREEN_R - 1, color, BG_COLOR);
}
// Verifica daca un punct (x,y) e in interiorul unui cerc (folosit la decuparea graficului)
bool isInsideCircle(int x, int y, int cx, int cy, int r) {
  int dx = x - cx, dy = y - cy;
  return (dx*dx + dy*dy) <= (r*r);   // comparam distanta la patrat (evitam radacina)
}

// =====================================================
// ANIMATIE ARCURI - cele 4 arcuri colorate rotitoare din tranzitii
// =====================================================
void drawFadingSpinningArcs(float spinAngle, float fadeFactor) {
  int val = (int)(255.0f * fadeFactor);              // intensitate dupa factorul de fade
  uint16_t colors[4] = {
    sprite.color565(0, val, val), sprite.color565(0, val, 0),
    sprite.color565(val, val, 0), sprite.color565(val, 0, 0)
  };
  int r_out = 108, thickness = max(1, (int)(10.0f * fadeFactor)), r_in = r_out - thickness, width = 70;
  for (int i = 0; i < 4; i++) {
    float centerPos = (i * 90.0f) - spinAngle + 3600.0f + TOP_OFFSET; // pozitia fiecarui arc
    int safeStart = ((int)(centerPos - width / 2.0f) % 360 + 360) % 360; // normalizat 0..359
    int safeEnd   = ((int)(centerPos + width / 2.0f) % 360 + 360) % 360;
    if (safeEnd < safeStart) {
      // arcul trece peste 0 -> il desenam in doua bucati
      sprite.drawSmoothArc(SCREEN_CX, SCREEN_CY, r_out, r_in, safeStart, 360,     colors[i], BG_COLOR);
      sprite.drawSmoothArc(SCREEN_CX, SCREEN_CY, r_out, r_in, 0,         safeEnd, colors[i], BG_COLOR);
    } else {
      sprite.drawSmoothArc(SCREEN_CX, SCREEN_CY, r_out, r_in, safeStart, safeEnd, colors[i], BG_COLOR);
    }
  }
}

// =====================================================
// TRANZITII - animatii intre ecrane
// =====================================================
// Animatie de intrare (arcuri care apar, optional logo "MENTPREV")
void playMenuTransitionIn(bool showHello) {
  unsigned long start = millis(), duration = 1200;
  float targetSpin = currentAngle;
  while (millis() - start < duration) {
    sprite.fillSprite(BG_COLOR);
    float t = constrain((float)(millis() - start) / duration, 0.0f, 1.0f); // progres 0..1
    float inv = 1.0f - t, easeOut = 1.0f - (inv * inv * inv);               // curba de incetinire
    drawFadingSpinningArcs(targetSpin + 720.0f * (1.0f - easeOut), t);
    if (showHello) {
      int val = (int)(255.0f * t);
      sprite.setTextColor(sprite.color565(val, val, val));
      sprite.drawString("MENTPREV", SCREEN_CX, SCREEN_CY, 4);
    }
    drawCircularClipBorder(sprite.color565(20,20,20));
    sprite.pushSprite(0, 0);
    delay(16);
  }
}

// Animatie de iesire (arcuri care se rotesc si dispar)
void playMenuTransitionOut() {
  unsigned long start = millis(), duration = 800;
  float startSpin = currentAngle;
  while (millis() - start < duration) {
    sprite.fillSprite(BG_COLOR);
    float t = constrain((float)(millis() - start) / duration, 0.0f, 1.0f);
    drawFadingSpinningArcs(startSpin - (720.0f * t * t * t), 1.0f - t);
    drawCircularClipBorder(sprite.color565(20,20,20));
    sprite.pushSprite(0, 0);
    delay(16);
  }
}

// Oprire completa a dispozitivului (animatie "BYE!", apoi taie alimentarea prin latch)
void doShutdown() {
  if (wifiStarted) wifiStop();                       // oprim WiFi curat
  unsigned long start = millis(), duration = 1600;
  float startSpin = currentAngle;
  while (millis() - start < duration) {
    sprite.fillSprite(BG_COLOR);
    float t = constrain((float)(millis() - start) / duration, 0.0f, 1.0f);
    float fade = 1.0f - t;
    drawFadingSpinningArcs(startSpin - (1080.0f * t * t * t), fade);
    sprite.setTextColor(sprite.color565((int)(255*fade), (int)(255*fade), (int)(255*fade)));
    sprite.drawString("BYE!", SCREEN_CX, SCREEN_CY, 4);
    drawCircularClipBorder(sprite.color565(20,20,20));
    sprite.pushSprite(0, 0);
    delay(16);
  }
  sprite.fillSprite(BG_COLOR);
  sprite.pushSprite(0, 0);
  digitalWrite(WIFI_LED_PIN, LOW);                   // stingem LED-urile
  digitalWrite(STATUS_LED_PIN, LOW);
  digitalWrite(DISPLAY_PWR_PIN, HIGH);               // stingem ecranul
  delay(10);
  digitalWrite(PWR_HOLD_PIN, LOW);                   // taiem alimentarea (latch off)
  while (1);                                         // nu ar trebui sa ajunga aici
}

// =====================================================
// SCAN FISIERE - listeaza toate fisierele .csv din radacina SD
// =====================================================
void scanLogFiles() {
  logFileCount = 0;
  File root = SD.open("/");
  if (!root) return;
  File entry;
  while ((entry = root.openNextFile()) && logFileCount < MAX_LOG_FILES) {
    if (!entry.isDirectory()) {
      const char* fn = entry.name();
      // pastram doar fisierele .csv (excludem utilaje.txt etc.)
      int len = strlen(fn);
      bool isCsv = (len > 4) &&
                   (strcasecmp(fn + len - 4, ".csv") == 0);
      if (isCsv) {
        // unele versiuni de SD lib intorc numele fara '/', altele cu.
        // normalizam: stocam cu '/' in fata.
        if (fn[0] == '/') {
          strncpy(logFileList[logFileCount], fn, 47);
        } else {
          logFileList[logFileCount][0] = '/';
          strncpy(logFileList[logFileCount] + 1, fn, 46);
        }
        logFileList[logFileCount][47] = '\0';        // garantam terminarea sirului
        logFileCount++;
      }
    }
    entry.close();
  }
  root.close();
}

