// Lista fisierelor .csv ca JSON (nume + dimensiune), consumata de pagina principala
void handleWebList() {
  scanLogFiles();                                    // reciteste fisierele de pe SD
  String json = "{\"files\":[";
  for (int i = 0; i < logFileCount; i++) {
    File f = SD.open(logFileList[i], FILE_READ);
    uint32_t sz = 0;
    if (f) { sz = f.size(); f.close(); }             // citim dimensiunea
    char szBuf[16];
    if (sz < 1024) snprintf(szBuf, sizeof(szBuf), "%lu B", sz);       // sub 1 KB -> bytes
    else           snprintf(szBuf, sizeof(szBuf), "%lu KB", sz / 1024);// altfel KB
    if (i > 0) json += ",";
    json += "{\"name\":\"";
    json += (logFileList[i] + 1);                    // +1 sare peste '/' din fata
    json += "\",\"size\":\"";
    json += szBuf;
    json += "\"}";
  }
  json += "]}";
  webServer.send(200, "application/json", json);
}

// Descarca un fisier de pe SD ca atasament (parametru ?f=nume)
void handleWebDownload() {
  if (!webServer.hasArg("f")) { webServer.send(400, "text/plain", "lipsa parametru f"); return; }
  String name = webServer.arg("f");
  String path = "/" + name;
  File f = SD.open(path, FILE_READ);
  if (!f) { webServer.send(404, "text/plain", "fisier inexistent"); return; }
  webServer.sendHeader("Content-Disposition", "attachment; filename=" + name); // forteaza download
  webServer.streamFile(f, "text/csv");               // trimite continutul fisierului
  f.close();
}

