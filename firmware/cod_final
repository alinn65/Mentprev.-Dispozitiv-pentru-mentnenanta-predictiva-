// =====================================================
// UTILAJE - incarcare/salvare pe SD + nume fisier
// =====================================================
// Citeste numele utilajelor din fisierul de pe SD (cate unul pe linie)
void loadMachineNames() {
  machineCount = 0;
  File f = SD.open(MACHINES_FILE, FILE_READ);
  if (!f) return;                                    // fisier inexistent -> niciun utilaj
  while (f.available() && machineCount < MAX_MACHINES) {
    String line = f.readStringUntil('\n');
    line.trim();                                     // eliminam spatii/CR
    if (line.length() == 0) continue;                // sarim liniile goale
    line.toCharArray(machineNames[machineCount], MACHINE_NAME_LEN);
    machineCount++;
  }
  f.close();
  Serial.printf("Utilaje incarcate: %d\n", machineCount);
}

// Rescrie complet fisierul de utilaje pe SD (suprascriere)
void saveMachineNames() {
  // suprascriem fisierul
  if (SD.exists(MACHINES_FILE)) SD.remove(MACHINES_FILE);
  File f = SD.open(MACHINES_FILE, FILE_WRITE);
  if (!f) return;
  for (int i = 0; i < machineCount; i++) f.println(machineNames[i]);
  f.close();
}

// Construieste numele fisierului de log: "/utilaj_AAAALLZZ_HHMM.csv"
void buildLogFileName() {
  char nameClean[MACHINE_NAME_LEN];
  if (machineCount > 0 && selectedMachine < machineCount) {
    strncpy(nameClean, machineNames[selectedMachine], MACHINE_NAME_LEN);
    nameClean[MACHINE_NAME_LEN - 1] = '\0';          // garantam terminarea sirului
  } else {
    strcpy(nameClean, "log");                        // fara utilaj selectat -> nume generic
  }
  // inlocuim spatiile cu _ ca sa fie nume de fisier valid
  for (char* p = nameClean; *p; p++) if (*p == ' ') *p = '_';

  if (rtcAvailable) {
    // nume cu data si ora reala -> fisiere auto-documentate si unice
    snprintf(currentLogFile, sizeof(currentLogFile), "/%s_20%02d%02d%02d_%02d%02d.csv",
             nameClean, rtcCache.year, rtcCache.month, rtcCache.day,
             rtcCache.hour, rtcCache.min);
  } else {
    // fara RTC, folosim un index ca sa nu suprascriem fisiere existente
    int n = 1;
    do {
      snprintf(currentLogFile, sizeof(currentLogFile), "/%s_%d.csv", nameClean, n);
      n++;
    } while (SD.exists(currentLogFile) && n < 999);
  }
  logIndex = 1;                                      // resetam contorul de randuri
}

