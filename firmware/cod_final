// =====================================================
// PROGRESS SCREEN - inel de progres pentru calibrare (fara artefacte)
// =====================================================
void drawProgressScreen(const char* label, int step, int total) {
  sprite.fillSprite(BG_COLOR);

  float progress = constrain((float)step / (float)total, 0.0f, 1.0f);

  // Inel de fundal (continuu, un singur arc complet) - fara segmente suprapuse
  sprite.drawSmoothArc(SCREEN_CX, SCREEN_CY, 110, 102, 0, 360,
                       sprite.color565(22,22,22), BG_COLOR);

  // Arc de progres: incepe sus (270 grade) si creste in sens orar.
  // Folosim un singur drawSmoothArc cand nu trece de 360, si doar
  // doua bucati cand wrap-uieste -> elimina artefactele de suprapunere.
  int sweep = (int)(progress * 360.0f);
  if (sweep > 0) {
    int startA = 270;                 // sus
    int endA   = startA + sweep;      // sens orar
    if (endA <= 360) {
      sprite.drawSmoothArc(SCREEN_CX, SCREEN_CY, 110, 102,
                           startA, endA, TFT_CYAN, sprite.color565(22,22,22));
    } else {
      // partea 1: de la 270 la 360
      sprite.drawSmoothArc(SCREEN_CX, SCREEN_CY, 110, 102,
                           startA, 360, TFT_CYAN, sprite.color565(22,22,22));
      // partea 2: de la 0 la restul
      int rest = endA - 360;
      if (rest > 0)
        sprite.drawSmoothArc(SCREEN_CX, SCREEN_CY, 110, 102,
                             0, rest, TFT_CYAN, sprite.color565(22,22,22));
    }
  }

  // Text central: eticheta + procent
  sprite.setTextColor(TFT_CYAN);
  sprite.drawString(label, SCREEN_CX, SCREEN_CY-22, 2);
  char pBuf[8]; sprintf(pBuf, "%d%%", (int)(progress*100));
  sprite.setTextColor(TFT_WHITE);
  sprite.drawString(pBuf, SCREEN_CX, SCREEN_CY+14, 4);

  drawCircularClipBorder(sprite.color565(25,25,25));
  sprite.pushSprite(0, 0);
}

// =====================================================
// CALIBRARE - aduna esantioane si invata o referinta (ambient sau masina)
// targetBuffer: unde acumulam spectrul mediu
// captureOffsetsAndOrientation: la Step 1, invatam si offset-ul gravitatiei + montajul
// captureLearnedVibration: la Step 2, invatam nivelul de vibratie sanatos
// =====================================================
bool runCalibration(double* targetBuffer, bool captureOffsetsAndOrientation, bool captureLearnedVibration) {
  int captureCount = SAMPLING_COUNTS[currentSamplingIndex];   // cate esantioane (dupa durata aleasa)
  for (int i = 0; i < FFT_BINS; i++) targetBuffer[i] = 0.0;
  float tX = 0, tY = 0, tZ = 0, vS = 0;                       // acumulatori
  int   valid = 0;
  double    tmpF[FFT_BINS];
  AccelData e;

  for (int s = 0; s < captureCount; s++) {
    if (getSharedSnapshot(tmpF, &e)) {
      for (int i = 0; i < FFT_BINS; i++) targetBuffer[i] += tmpF[i];  // insumam spectrul
      tX += e.acceleration.x; tY += e.acceleration.y; tZ += e.acceleration.z;
      if (captureLearnedVibration) {
        // magnitudinea vibratiei fata de offset-ul de gravitatie
        float vx = e.acceleration.x - offX, vy = e.acceleration.y - offY, vz = e.acceleration.z - offZ;
        vS += sqrtf(vx*vx + vy*vy + vz*vz);
      }
      valid++;
    }
    drawProgressScreen("SAMPLING DATA...", s+1, captureCount);  // bara de progres
    vTaskDelay(pdMS_TO_TICKS(15));
  }

  if (valid == 0) return false;                          // niciun esantion valid -> esec
  for (int i = 0; i < FFT_BINS; i++) targetBuffer[i] /= valid;  // medie spectrala
  if (captureOffsetsAndOrientation) {
    offX = tX / valid; offY = tY / valid; offZ = tZ / valid;     // offset-ul mediu (gravitatia)
    currentMode = detectMountModeFromGravity(offX, offY, offZ);  // deducem montajul
    accelAxis = selectAccelAxis(currentMode);   // alege axa pt FFT-ul de vibratie
    drawCenteredMessage("MOUNT DETECTED", mountModeToString(currentMode), TFT_CYAN);
    vTaskDelay(pdMS_TO_TICKS(900));
  }
  if (captureLearnedVibration && valid > 0) {
    learnedVib = vS / valid;                             // nivelul de vibratie de referinta
    // invatam si spectrul de vibratie sanatos (snapshot din spectrul curent)
    if (xSemaphoreTake(mutex, pdMS_TO_TICKS(50)) == pdTRUE) {
      for (int i = 0; i < ACC_FFT_BINS; i++) learnedAccelFFT[i] = sharedAccelFFT[i];
      xSemaphoreGive(mutex);
    }
  }
  return true;
}

// =====================================================
// MONITORING - calculeaza HealthScore-ul din datele curente
// Compara spectrul si vibratia curenta cu referintele invatate la calibrare.
// =====================================================
void updateMonitoring(const double* currentRaw, const AccelData& e) {
  // acceleratia relativa fata de offset (cat se misca peste gravitatie)
  float relX = e.acceleration.x - offX;
  float relY = e.acceleration.y - offY;
  float relZ = e.acceleration.z - offZ;
  float dX = 0.0f, dY = 0.0f;
  // alegem cele doua axe utile pentru afisarea punctului, in functie de montaj
  if      (currentMode == TOP)   { dX = relX; dY = relY; }
  else if (currentMode == FRONT) { dX = relX; dY = relZ; }
  else                           { dX = relY; dY = relZ; }

  // netezim spectrul curent (filtru exponential) ca sa nu sara afisajul
  for (int i = 0; i < FFT_BINS; i++)
    smoothedFFT[i] = smoothedFFT[i] * (1.0f - FFT_SMOOTH_ALPHA) + currentRaw[i] * FFT_SMOOTH_ALPHA;

  float cPwr = computeCleanPower(smoothedFFT, 2, FFT_BINS, FFT_NOISE_GATE);   // puterea acustica curenta
  float rVib = sqrtf(relX*relX + relY*relY + relZ*relZ);                      // magnitudinea vibratiei
  smoothVib  = smoothVib * (1.0f - VIB_SMOOTH_ALPHA) + rVib * VIB_SMOOTH_ALPHA; // vibratie netezita

  float vRatio  = (learnedVib > 0.01f) ? (smoothVib / learnedVib) : 1.0f;     // raport fata de referinta
  vibAlertLevel = max(0.0f, vRatio - 1.0f);                                   // cat depaseste normalul
  // masina e considerata oprita daca puterea si vibratia sunt foarte mici
  isMachineOff  = (cPwr < (learnedPower * MACHINE_OFF_POWER_RATIO)) && (smoothVib < MACHINE_OFF_VIB_THRESHOLD);

  if (!isMachineOff) {
    // diferenta spectrala fata de semnatura sanatoasa invatata
    float diff = 0.0f;
    for (int i = 2; i < FFT_BINS; i++)
      diff += fabs(max(0.0, smoothedFFT[i] - ambientFFT[i] * AMBIENT_MULTIPLIER) - machineFFT[i]);
    diff += vibAlertLevel * VIBRATION_WEIGHT;            // adaugam contributia vibratiei
    float iHealth = constrain(100.0f - diff / HEALTH_DIFF_SCALE, 0.0f, 100.0f); // health instantaneu
    // acumulam anomalia in timp: creste daca e mereu prost, scade daca revine
    anomalyScore  = constrain(anomalyScore + (iHealth < 75.0f ? ANOMALY_ATTACK : -ANOMALY_RELEASE), 0.0f, ANOMALY_MAX);
    // penalizare doar daca anomalia persista peste prag (ignora varfuri izolate)
    float penalty = (anomalyScore > ANOMALY_THRESHOLD) ? min(40.0f, (anomalyScore - ANOMALY_THRESHOLD) * 0.9f) : 0.0f;
    float tHealth = constrain(iHealth - penalty, 0.0f, 100.0f);
    // netezim health-ul final (raspuns lent, stabil)
    healthScore   = healthScore * (1.0f - HEALTH_SMOOTH_ALPHA) + tHealth * HEALTH_SMOOTH_ALPHA;
  } else {
    // masina oprita: relaxam anomalia si readucem health-ul spre 100
    anomalyScore  *= 0.96f;
    vibAlertLevel *= 0.95f;
    healthScore    = healthScore * 0.96f + 100.0f * 0.04f;
  }

  // in regim de alerta logam mai des
  sendInterval = (!isMachineOff && healthScore < HEALTH_ALERT_THRESHOLD)
    ? SERIAL_INTERVAL_ALERT_MS : SERIAL_INTERVAL_NORMAL_MS;

  if (millis() - lastSerialSend >= (unsigned long)sendInterval) {
    // Logam si FFT brut + accel + timestamp RTC. Folosim spectrul curat (smoothedFFT)
    // ca "FFT brut" reprezentativ pentru randul curent.
    // snapshot spectru vibratie pentru logging
    double accSpecSnap[ACC_FFT_BINS];
    if (xSemaphoreTake(mutex, pdMS_TO_TICKS(10)) == pdTRUE) {
      for (int i = 0; i < ACC_FFT_BINS; i++) accSpecSnap[i] = sharedAccelFFT[i];
      xSemaphoreGive(mutex);
    } else {
      for (int i = 0; i < ACC_FFT_BINS; i++) accSpecSnap[i] = 0.0;
    }
    logDataToSD((int)healthScore, cPwr, smoothVib, vibAlertLevel, anomalyScore, e, smoothedFFT, accSpecSnap);
    lastSerialSend = millis();
  }

  // culoarea de afisare in functie de stare/health
  uint16_t c = isMachineOff ? TFT_BLUE
    : (healthScore > 75.0f ? TFT_GREEN : (healthScore > 45.0f ? TFT_YELLOW : TFT_RED));

  drawMonitoringUI(dX, dY, mountModeToString(currentMode), c, vibAlertLevel);
}

// =====================================================
// MONITORING UI - ecranul live: inel health, spectre, punct vibratie, bara
// =====================================================
void drawMonitoringUI(float dispX, float dispY, const char* mountName, uint16_t color, float vibLevel) {
  sprite.fillSprite(BG_COLOR);
  // inel de fundal + arc de health proportional cu scorul
  sprite.drawSmoothArc(SCREEN_CX, SCREEN_CY, 112, 104, 0, 360, sprite.color565(28,28,28), BG_COLOR);
  int arcDeg = map((int)healthScore, 0, 100, 0, 360);
  if (arcDeg > 0)
    sprite.drawSmoothArc(SCREEN_CX, SCREEN_CY, 112, 104, 270, (270 + arcDeg) % 360, color, BG_COLOR);

  // spectru MICROFON, desenat ca bare radiale (inel exterior)
  const float FFT_ARC_START = 150.0f, FFT_ARC_SPAN = 240.0f;
  for (int i = 2; i < 40; i++) {
    float t   = (float)(i-2) / 38.0f;
    float rad = (FFT_ARC_START + t * FFT_ARC_SPAN) * DEG_TO_RAD;
    float mag = (float)max(0.0, smoothedFFT[i] - ambientFFT[i] * AMBIENT_MULTIPLIER); // peste ambient
    int   amp = constrain((int)(mag / 500.0f), 0, 22);
    if (amp > 0) {
      sprite.drawWideLine(
        SCREEN_CX + (int)(72.0f * cosf(rad)), SCREEN_CY + (int)(72.0f * sinf(rad)),
        SCREEN_CX + (int)((72.0f+amp) * cosf(rad)), SCREEN_CY + (int)((72.0f+amp) * sinf(rad)),
        2, color);
    }
  }

  // --- Spectru de VIBRATIE (accelerometru), inel interior, culoare distincta ---
  if (xSemaphoreTake(mutex, pdMS_TO_TICKS(5)) == pdTRUE) {
    for (int i = 0; i < ACC_FFT_BINS; i++) accelSpectrum[i] = sharedAccelFFT[i];
    xSemaphoreGive(mutex);
  }
  uint16_t vibColor = sprite.color565(150, 100, 255);   // mov - vibratie
  for (int i = 2; i < 40; i++) {
    float t   = (float)(i-2) / 38.0f;
    float rad = (FFT_ARC_START + t * FFT_ARC_SPAN) * DEG_TO_RAD;
    float mag = (float)accelSpectrum[i];
    int   amp = constrain((int)(mag / 2.0f), 0, 18);    // scalare proprie pt vibratie
    if (amp > 0) {
      sprite.drawWideLine(
        SCREEN_CX + (int)(50.0f * cosf(rad)), SCREEN_CY + (int)(50.0f * sinf(rad)),
        SCREEN_CX + (int)((50.0f - amp) * cosf(rad)), SCREEN_CY + (int)((50.0f - amp) * sinf(rad)),
        1, vibColor);
    }
  }

  // punctul care arata directia/amplitudinea vibratiei curente
  int dotX = SCREEN_CX + (int)(dispX * 10.0f);
  int dotY = SCREEN_CY - (int)(dispY * 10.0f);
  float ddx = dotX - SCREEN_CX, ddy = dotY - SCREEN_CY, dd = sqrtf(ddx*ddx + ddy*ddy);
  if (dd > 32.0f) { dotX = SCREEN_CX + (int)(ddx/dd*32); dotY = SCREEN_CY + (int)(ddy/dd*32); } // limitam raza

  if (!isMachineOff) {
    sprite.drawLine(SCREEN_CX, SCREEN_CY, dotX, dotY, sprite.color565(60,60,60));
    sprite.fillCircle(dotX, dotY, 5, color);
    sprite.fillCircle(SCREEN_CX, SCREEN_CY, 3, sprite.color565(80,80,80));
  } else {
    sprite.drawSmoothCircle(SCREEN_CX, SCREEN_CY, 12, TFT_BLUE, BG_COLOR);  // standby
  }

  // valoarea health-ului, mare, in centru
  sprite.setTextColor(TFT_WHITE);
  sprite.drawNumber((int)healthScore, SCREEN_CX, SCREEN_CY-8, 6);
  sprite.setTextColor(TFT_DARKGREY);
  sprite.drawString(mountName, SCREEN_CX, 42, 2);   // orientarea de montaj

  if (rtcAvailable) {
    char timeBuf[9]; sprintf(timeBuf, "%02d:%02d", rtcCache.hour, rtcCache.min);
    sprite.setTextColor(sprite.color565(45,45,45));
    sprite.drawString(timeBuf, SCREEN_CX, 57, 1);
  }

  // eticheta de stare textuala
  sprite.setTextColor(isMachineOff ? TFT_BLUE : color);
  sprite.drawString(isMachineOff ? "STANDBY" : (healthScore < 50.0f ? "CHECK!" : "OK"), SCREEN_CX, SCREEN_CY+36, 2);

  // bara verticala de vibratie (in dreapta)
  const int VIB_CX = SCREEN_CX + 82, VIB_CY = SCREEN_CY + 20, barH = 55;
  int fillH = (int)(constrain(vibLevel / 1.5f, 0.0f, 1.0f) * barH);
  sprite.drawRoundRect(VIB_CX-6, VIB_CY-barH, 12, barH, 3, sprite.color565(40,40,40));
  if (fillH > 0) sprite.fillRoundRect(VIB_CX-4, VIB_CY-fillH, 8, fillH, 2, color);
  sprite.setTextColor(sprite.color565(60,60,60));
  sprite.drawString("V", VIB_CX, VIB_CY+6, 1);

  drawCircularClipBorder(sprite.color565(25,25,25));
  sprite.pushSprite(0, 0);
}

// =====================================================
// SD LOGGING - scrierea datelor in fisierul CSV
// =====================================================
// Pregateste un nume de fisier liber de tip /log_N.csv (cazul fara utilaj selectat)
void prepareNextLogFile() {
  int fileNum = 1;
  while (true) {
    sprintf(currentLogFile, "/log_%d.csv", fileNum);
    if (!SD.exists(currentLogFile)) break;   // primul nume liber
    fileNum++;
  }
  logIndex = 1;
}

// Scrie un rand complet in CSV: metadate + spectru microfon + spectru vibratie
void logDataToSD(int hScore, float pwr, float sVib, float vAlert, float aScore,
                 const AccelData& e, const double* rawFFT, const double* accFFTspec) {
  File dataFile = SD.open(currentLogFile, SD.exists(currentLogFile) ? FILE_APPEND : FILE_WRITE);
  if (!dataFile) return;

  // Header la primul rand (cand fisierul e gol)
  if (dataFile.size() == 0) {
    dataFile.print("Index,Data,Ora,Timp(ms),HealthScore,Power,SmoothVib,VibAlert,Anomaly,AccX,AccY,AccZ,AccelAxis");
    for (int i = 0; i < FFT_BINS; i++) dataFile.printf(",MIC%d", i);       // spectru microfon
    for (int i = 0; i < ACC_FFT_BINS; i++) dataFile.printf(",VIB%d", i);   // spectru vibratie
    dataFile.println();
  }

  char dBuf[12], tBuf[12];
  rtcDateString(dBuf, sizeof(dBuf));   // data curenta
  rtcTimeString(tBuf, sizeof(tBuf));   // ora curenta

  const char* axisName = (accelAxis == 0) ? "X" : (accelAxis == 1) ? "Y" : "Z";  // axa de vibratie

  // Coloane fixe (HealthScore ramane al 5-lea camp -> compatibil cu graficul de pe ecran)
  dataFile.printf("%lu,%s,%s,%lu,%d,%.1f,%.3f,%.3f,%.1f,%.3f,%.3f,%.3f,%s",
    logIndex++, dBuf, tBuf, millis(),
    hScore, pwr, sVib, vAlert, aScore,
    e.acceleration.x, e.acceleration.y, e.acceleration.z, axisName);

  // spectru microfon (MIC0..MICn)
  for (int i = 0; i < FFT_BINS; i++) dataFile.printf(",%.1f", rawFFT[i]);
  // spectru vibratie accelerometru (VIB0..VIBn)
  for (int i = 0; i < ACC_FFT_BINS; i++) dataFile.printf(",%.2f", accFFTspec[i]);
  dataFile.println();

  dataFile.close();
}

// =====================================================
// INIT HARDWARE - initializarea fiecarui periferic
// =====================================================
// Accelerometrul MMA8452Q pe I2C (scala +-8g, rata 800 Hz)
bool initAccelerometer() {
  Wire.begin(I2C_SDA, I2C_SCL);                // SDA=8, SCL=9 pentru AMBELE dispozitive I2C
  if (!accel.begin(Wire, 0x1C)) return false;  // MMA8452Q la 0x1C (SA0=LOW)
  accel.setScale(SCALE_8G);
  accel.setDataRate(ODR_800);
  return true;
}

// Ecranul TFT + sprite-ul buffer in memorie
bool initDisplay() {
  tft.init();
  tft.setRotation(0);
  tft.fillScreen(BG_COLOR);
  sprite.setColorDepth(8);                     // 8 biti/pixel (economie de RAM)
  if (!sprite.createSprite(240, 240)) return false;
  sprite.setTextDatum(MC_DATUM);               // text centrat implicit
  return true;
}

// Cardul SD pe magistrala SPI dedicata
bool initSDCard() {
  spiSD.begin(SD_SCK, SD_MISO, SD_MOSI, SD_CS_PIN);
  return SD.begin(SD_CS_PIN, spiSD, 4000000);  // 4 MHz
}

// Cele doua mutex-uri (date partajate + acces I2C)
bool initMutex() {
  mutex = xSemaphoreCreateMutex();
  i2cMutex = xSemaphoreCreateMutex();
  return (mutex != nullptr && i2cMutex != nullptr);
}

// Interfata I2S pentru microfonul digital
bool initI2S() {
  i2s_config_t i2s_c = {};
  i2s_c.mode                 = (i2s_mode_t)(I2S_MODE_MASTER | I2S_MODE_RX);  // master, doar receptie
  i2s_c.sample_rate          = SAMPLING_FREQ;
  i2s_c.bits_per_sample      = I2S_BITS_PER_SAMPLE_32BIT;
  i2s_c.channel_format       = I2S_CHANNEL_FMT_ONLY_LEFT;   // un singur canal
  i2s_c.communication_format = I2S_COMM_FORMAT_STAND_I2S;
  i2s_c.intr_alloc_flags     = ESP_INTR_FLAG_LEVEL1;
  i2s_c.dma_buf_count        = 4;
  i2s_c.dma_buf_len          = SAMPLES;
  i2s_c.use_apll             = false;
  i2s_pin_config_t pins = {
    .bck_io_num   = I2S_SCK,
    .ws_io_num    = I2S_WS,
    .data_out_num = I2S_PIN_NO_CHANGE,   // nu transmitem nimic
    .data_in_num  = I2S_SD
  };
  if (i2s_driver_install(I2S_NUM_0, &i2s_c, 0, NULL) != ESP_OK) return false;
  if (i2s_set_pin(I2S_NUM_0, &pins)                  != ESP_OK) return false;
  return true;
}

// Deduce orientarea de montaj din axa pe care "cade" gravitatia
MountMode detectMountModeFromGravity(float ax, float ay, float az) {
  float aX = fabs(ax), aY = fabs(ay), aZ = fabs(az);
  if (aZ >= aX && aZ >= aY) return TOP;     // gravitatia pe Z -> montaj orizontal
  if (aY >= aX && aY >= aZ) return FRONT;   // gravitatia pe Y -> montaj frontal
  return SIDE;                              // gravitatia pe X -> montaj lateral
}

// Converteste orientarea in text pentru afisare
const char* mountModeToString(MountMode mode) {
  return mode == TOP ? "TOP" : (mode == FRONT ? "FRONT" : "SIDE");
}
