// Seteaza ora RTC din web (parametri ?d=data ?t=ora)
void handleWebSetTime() {
  if (rtcAvailable && webServer.hasArg("d") && webServer.hasArg("t")) {
    String d = webServer.arg("d");   // AAAA-LL-ZZ
    String t = webServer.arg("t");   // HH:MM:SS
    if (d.length() >= 10 && t.length() >= 8) {       // validare minimala de lungime
      RtcTime nt;
      nt.year  = d.substring(2,4).toInt();           // luam ultimele doua cifre ale anului
      nt.month = d.substring(5,7).toInt();
      nt.day   = d.substring(8,10).toInt();
      nt.hour  = t.substring(0,2).toInt();
      nt.min   = t.substring(3,5).toInt();
      nt.sec   = t.substring(6,8).toInt();
      if (rtcWrite(nt)) rtcCache = nt;               // scriem in RTC si actualizam cache-ul
    }
  }
  webServer.sendHeader("Location", "/settings");
  webServer.send(303, "text/plain", "ok");
}

