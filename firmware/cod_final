// =====================================================
// GRAFIC DIN SD - deseneaza evolutia HealthScore dintr-un fisier .csv
// HealthScore e al 5-lea camp: idx,data,ora,ms,HEALTH,...
// =====================================================
void drawPlotFromSD(const char* filepath) {
  // ecran de incarcare
  sprite.fillSprite(BG_COLOR);
  sprite.setTextColor(TFT_YELLOW);
  sprite.drawString("SE INCARCA...", SCREEN_CX, SCREEN_CY-10, 2);
  sprite.setTextColor(TFT_DARKGREY);
  sprite.drawString(filepath+1, SCREEN_CX, SCREEN_CY+12, 1);
  drawCircularClipBorder(sprite.color565(25,25,25));
  sprite.pushSprite(0, 0);

  File file = SD.open(filepath, FILE_READ);
  if (!file) {
    // eroare de deschidere
    sprite.fillSprite(BG_COLOR);
    sprite.setTextColor(TFT_RED);
    sprite.drawString("EROARE SD", SCREEN_CX, SCREEN_CY-10, 4);
    sprite.setTextColor(TFT_DARKGREY);
    sprite.drawString(filepath+1, SCREEN_CX, SCREEN_CY+14, 1);
    drawCircularClipBorder(sprite.color565(25,25,25));
    sprite.pushSprite(0, 0);
    return;
  }

  uint8_t plotData[240]; int dataCount = 0;          // pana la 240 de puncte de health
  file.readStringUntil('\n');   // sare peste header
  while (file.available()) {
    String line = file.readStringUntil('\n');
    // extragem al 5-lea camp (HealthScore), adica dupa a 4-a virgula
    int comma = -1;
    int start = 0;
    int field = 0;
    int hVal = -1;
    for (int searched = 0; searched < 5; searched++) {
      comma = line.indexOf(',', start);
      if (searched == 4) {
        // campul HealthScore este intre 'start' si 'comma'
        int endPos = (comma < 0) ? line.length() : comma;
        hVal = line.substring(start, endPos).toInt();
        break;
      }
      if (comma < 0) break;
      start = comma + 1;
    }
    if (hVal < 0) continue;                          // linie invalida -> sarim
    int h = constrain(hVal, 0, 100);
    if (dataCount < 240) plotData[dataCount++] = (uint8_t)h;
    else { memmove(plotData, plotData+1, 239); plotData[239] = (uint8_t)h; } // buffer plin -> glisam
    yield();                                         // cedeaza CPU (fisiere mari)
  }
  file.close();

  sprite.fillSprite(BG_COLOR);
  if (dataCount == 0) {
    sprite.setTextColor(TFT_YELLOW);
    sprite.drawString("FISIER GOL", SCREEN_CX, SCREEN_CY, 4);
    drawCircularClipBorder(sprite.color565(25,25,25));
    sprite.pushSprite(0, 0);
    return;
  }

  // parametrii arcului pe care se deseneaza graficul (un sector circular)
  const float ARC_START = 145.0f, ARC_END = 395.0f, ARC_SPAN = ARC_END - ARC_START;
  const int   PLOT_INNER = 45, PLOT_OUTER = 100;     // raze: 0% spre exterior, 100% spre interior
  const uint16_t gridColor = sprite.color565(30,30,30);

  // cercuri de grila la 25/50/75/100%
  for (int pct : {25, 50, 75, 100}) {
    int r = map(pct, 0, 100, PLOT_OUTER, PLOT_INNER);
    sprite.drawSmoothCircle(SCREEN_CX, SCREEN_CY, r, gridColor, BG_COLOR);
  }
  int r75 = map(75, 0, 100, PLOT_OUTER, PLOT_INNER);
  sprite.drawSmoothCircle(SCREEN_CX, SCREEN_CY, r75, sprite.color565(40,60,20), BG_COLOR); // pragul 75% evidentiat

  sprite.setTextColor(sprite.color565(60,60,60));
  sprite.drawString("100", SCREEN_CX, SCREEN_CY - PLOT_INNER - 8, 1);
  sprite.drawString("75",  SCREEN_CX, SCREEN_CY - r75 - 7, 1);
  sprite.drawString("0",   SCREEN_CX, SCREEN_CY - PLOT_OUTER - 8, 1);

  // traseaza curba health-ului punct cu punct, culoare dupa valoare
  int pts = min(dataCount, 240);
  float prevX = 0, prevY = 0; bool hasPrev = false;
  for (int i = 0; i < pts; i++) {
    float t   = (pts > 1) ? ((float)i / (pts-1)) : 0.0f;  // pozitie 0..1 pe arc
    float deg = ARC_START + t * ARC_SPAN;
    float rad = deg * DEG_TO_RAD;
    int   h   = plotData[dataCount - pts + i];
    float r   = (float)map(h, 0, 100, PLOT_OUTER, PLOT_INNER); // raza dupa health
    float px  = SCREEN_CX + r * cosf(rad), py = SCREEN_CY + r * sinf(rad);
    if (!isInsideCircle((int)px, (int)py, SCREEN_CX, SCREEN_CY, SCREEN_R-2)) { hasPrev = false; continue; }
    uint16_t lc = (h > 75) ? TFT_GREEN : (h > 45) ? TFT_YELLOW : TFT_RED; // verde/galben/rosu
    if (hasPrev && isInsideCircle((int)prevX, (int)prevY, SCREEN_CX, SCREEN_CY, SCREEN_R-2))
      sprite.drawLine((int)prevX, (int)prevY, (int)px, (int)py, lc);     // segment intre puncte
    if (i == pts-1) sprite.fillCircle((int)px, (int)py, 3, TFT_WHITE);   // marcam ultimul punct
    prevX = px; prevY = py; hasPrev = true;
  }

  sprite.setTextColor(TFT_WHITE);
  sprite.drawString("HEALTH", SCREEN_CX, 18, 2);
  sprite.setTextColor(TFT_DARKGREY);
  sprite.drawString(filepath+1, SCREEN_CX, 32, 1);     // numele fisierului

  // valoarea finala, mare, in centru
  int lastH = plotData[dataCount-1];
  uint16_t hc = (lastH > 75) ? TFT_GREEN : (lastH > 45) ? TFT_YELLOW : TFT_RED;
  sprite.setTextColor(hc);
  sprite.drawNumber(lastH, SCREEN_CX, SCREEN_CY-10, 6);
  sprite.setTextColor(TFT_DARKGREY);
  sprite.drawString("%", SCREEN_CX+28, SCREEN_CY+14, 2);

  // statistici min/max pe tot fisierul
  uint8_t minH = 100, maxH = 0;
  for (int i = 0; i < dataCount; i++) { if (plotData[i] < minH) minH = plotData[i]; if (plotData[i] > maxH) maxH = plotData[i]; }
  char statBuf[24]; sprintf(statBuf, "min:%d  max:%d", minH, maxH);
  sprite.setTextColor(sprite.color565(60,60,60));
  sprite.drawString(statBuf, SCREEN_CX, SCREEN_CY+36, 1);
  char navBuf[24]; sprintf(navBuf, "%d / %d", plotCursor+1, logFileCount);  // pozitia in lista
  sprite.setTextColor(sprite.color565(55,55,55));
  sprite.drawString(navBuf, SCREEN_CX, 210, 1);
  drawCircularClipBorder(sprite.color565(25,25,25));
  sprite.pushSprite(0, 0);
}

// =====================================================
// DSP TASK - microfon I2S + FFT (ruleaza continuu pe core 0)
// Citeste esantioane audio, calculeaza spectrul si il publica partajat.
// =====================================================
void dspTask(void* pvParameters) {
  size_t  bytesIn = 0;
  int32_t sampleBuffer[SAMPLES];
  for (;;) {
    // citim un bloc de esantioane de la microfon (blocant pana sosesc date)
    if (i2s_read(I2S_NUM_0, sampleBuffer, sizeof(sampleBuffer), &bytesIn, portMAX_DELAY) == ESP_OK) {
      double mean = 0.0;
      // convertim esantioanele si calculam media (componenta continua)
      for (int i = 0; i < SAMPLES; i++) { vReal[i] = (double)(sampleBuffer[i] >> 14); vImag[i] = 0.0; mean += vReal[i]; }
      mean /= SAMPLES;
      for (int i = 0; i < SAMPLES; i++) vReal[i] -= mean;   // eliminam media (centram pe 0)
      FFT.windowing(FFT_WIN_TYP_HAMMING, FFT_FORWARD);      // fereastra Hamming (reduce scurgerile)
      FFT.compute(FFT_FORWARD);                             // calculam FFT
      FFT.complexToMagnitude();                             // convertim in magnitudine spectrala

      AccelData localAccel;
      // NU mai citim I2C aici - accelSamplingTask se ocupa de asta la rata fixa.
      // Luam ultima valoare disponibila (evita conflict pe magistrala I2C).
      localAccel.acceleration.x = lastAccX;
      localAccel.acceleration.y = lastAccY;
      localAccel.acceleration.z = lastAccZ;

      // publicam spectrul si acceleratia in zona partajata (sub mutex)
      if (xSemaphoreTake(mutex, portMAX_DELAY) == pdTRUE) {
        memcpy(sharedFFT, vReal, sizeof(double) * FFT_BINS);
        sharedAccel  = localAccel;
        sensorReady  = true;
        xSemaphoreGive(mutex);
      }
    }
    vTaskDelay(pdMS_TO_TICKS(2));   // cedeaza CPU
  }
}

// =====================================================
// TASK ESANTIONARE ACCELEROMETRU (rata fixa) + FFT
// =====================================================
// Alege axa cea mai relevanta pentru vibratie in functie de montaj.
// Gravitatia "sta" pe axa verticala, deci vibratia utila e mai vizibila
// pe celelalte axe. Alegem o axa orizontala fata de montaj.
int selectAccelAxis(MountMode mode) {
  // TOP   -> gravitatia pe Z, alegem X
  // FRONT -> gravitatia pe Y, alegem X
  // SIDE  -> gravitatia pe X, alegem Y
  if (mode == TOP)   return 0;  // X
  if (mode == FRONT) return 0;  // X
  return 1;                     // Y (SIDE)
}

// Esantioneaza accelerometrul la ACC_SAMPLE_HZ si umple buffer-ul.
// Cand buffer-ul e plin, calculeaza FFT-ul.
void accelSamplingTask(void* pvParameters) {
  const TickType_t period = pdMS_TO_TICKS(1000 / ACC_SAMPLE_HZ);  // 4ms la 250 Hz
  TickType_t lastWake = xTaskGetTickCount();
  int idx = 0;

  for (;;) {
    // citire accel pe axa selectata (protejat pe I2C, timeout mic)
    float val = 0.0f;
    float ax = lastAccX, ay = lastAccY, az = lastAccZ;  // valori de rezerva daca nu prindem mutex-ul
    if (xSemaphoreTake(i2cMutex, pdMS_TO_TICKS(2)) == pdTRUE) {
      if (accel.available()) accel.read();
      ax = accel.getCalculatedX() * G_TO_MS2;           // convertim in m/s^2
      ay = accel.getCalculatedY() * G_TO_MS2;
      az = accel.getCalculatedZ() * G_TO_MS2;
      xSemaphoreGive(i2cMutex);
    }
    // publicam ultima citire completa pentru dspTask (logging/health)
    lastAccX = ax; lastAccY = ay; lastAccZ = az;
    // selectam axa de vibratie pentru FFT
    if      (accelAxis == 0) val = ax;
    else if (accelAxis == 1) val = ay;
    else                     val = az;

    accSampleBuf[idx] = (double)val;
    idx++;

    if (idx >= ACC_SAMPLES) {
      idx = 0;
      computeAccelFFT();   // fereastra plina -> calculam spectrul de vibratie
    }

    // Mentine rata fixa, dar daca am ramas in urma (FFT/I2C a durat mult),
    // resincronizeaza si cedeaza CPU explicit ca sa nu infometam watchdog-ul.
    TickType_t now = xTaskGetTickCount();
    if ((now - lastWake) >= period) {
      // am ramas in urma: resetam referinta si cedam macar 1 tick
      lastWake = now;
      vTaskDelay(1);
    } else {
      vTaskDelayUntil(&lastWake, period);   // dormim exact pana la urmatorul esantion
    }
  }
}

// Calculeaza FFT pe bufferul de accelerometru si publica spectrul de vibratie
void computeAccelFFT() {
  // copiem din bufferul partajat si scoatem media (DC = gravitatie + offset)
  double mean = 0.0;
  for (int i = 0; i < ACC_SAMPLES; i++) {
    accReal[i] = accSampleBuf[i];
    accImag[i] = 0.0;
    mean += accReal[i];
  }
  mean /= ACC_SAMPLES;
  for (int i = 0; i < ACC_SAMPLES; i++) accReal[i] -= mean;  // centram pe 0 (eliminam gravitatia)

  accFFT.windowing(FFT_WIN_TYP_HAMMING, FFT_FORWARD);
  accFFT.compute(FFT_FORWARD);
  accFFT.complexToMagnitude();

  // pastram primele ACC_FFT_BINS bin-uri (sub mutex)
  if (xSemaphoreTake(mutex, pdMS_TO_TICKS(10)) == pdTRUE) {
    for (int i = 0; i < ACC_FFT_BINS; i++) sharedAccelFFT[i] = accReal[i];
    accelSpectrumReady = true;
    xSemaphoreGive(mutex);
  }
}

// Copiaza un snapshot consistent al spectrului si acceleratiei (pentru loop)
bool getSharedSnapshot(double* fftOut, AccelData* accelOut) {
  if (!sensorReady) return false;       // inca nu avem date valide
  if (xSemaphoreTake(mutex, pdMS_TO_TICKS(10)) == pdTRUE) {
    memcpy(fftOut, sharedFFT, sizeof(double) * FFT_BINS);
    *accelOut = sharedAccel;
    xSemaphoreGive(mutex);
    return true;
  }
  return false;
}

// Reseteaza toate datele de calibrare si scorurile (inceput de sesiune)
void clearBuffers() {
  memset(ambientFFT,  0, sizeof(ambientFFT));
  memset(machineFFT,  0, sizeof(machineFFT));
  memset(smoothedFFT, 0, sizeof(smoothedFFT));
  learnedPower = 0.0f; learnedVib = 0.0f; smoothVib = 0.0f;
  healthScore  = 100.0f; anomalyScore = 0.0f; isMachineOff = false;
}

// Calculeaza "puterea curata": suma energiilor spectrale peste prag,
// dupa scaderea zgomotului ambiant. Reprezinta intensitatea semnalului util.
float computeCleanPower(const double* spectrum, int startBin, int endBin, float gateThreshold) {
  float total = 0.0f;
  for (int i = max(0, startBin); i < min(FFT_BINS, endBin); i++) {
    double clean = spectrum[i] - (ambientFFT[i] * AMBIENT_MULTIPLIER);
    if (clean > gateThreshold) total += (float)clean;   // numaram doar ce depaseste pragul de zgomot
  }
  return total;
}

