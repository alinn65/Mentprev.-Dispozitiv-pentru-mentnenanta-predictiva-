// =====================================================
// BUTOANE - structura si logica de debounce
// =====================================================
struct Button {
  int           pin;                        // pinul fizic al butonului
  bool          lastReading, stableState;   // ultima citire bruta + starea stabila confirmata
  unsigned long lastDebounce, pressStart;   // momentul ultimei schimbari + inceputul apasarii
  bool          wasPressed, longFired;      // apasare in evaluare + apasarea lunga deja raportata
};

// Butoanele active LOW (INPUT_PULLUP): apasat = LOW, eliberat = HIGH
Button navBtn = { NAV_BTN_PIN, HIGH, HIGH, 0, 0, false, false };
Button pwrBtn = { PWR_BTN_PIN, HIGH, HIGH, 0, 0, false, false };

// Actualizeaza starea unui buton cu anti-debounce (filtreaza tranzitiile false)
void updateButton(Button& b) {
  bool reading = digitalRead(b.pin);                  // citire bruta
  if (reading != b.lastReading) b.lastDebounce = millis(); // s-a schimbat -> resetam timer-ul
  b.lastReading = reading;
  if ((millis() - b.lastDebounce) > DEBOUNCE_MS) {    // citirea s-a stabilizat suficient
    if (reading != b.stableState) {
      b.stableState = reading;
      if (b.stableState == LOW) {                     // tranzitie spre apasat
        b.pressStart = millis();                      // retinem cand a inceput apasarea
        b.wasPressed = true;
        b.longFired  = false;
      }
    }
  }
}

// Detecteaza o apasare SCURTA: eliberata inainte de prag si fara sa fi declansat "lung"
bool clickShort(Button& b, unsigned long threshold) {
  updateButton(b);
  if (b.wasPressed && b.stableState == HIGH && !b.longFired) { // a fost eliberat
    if (millis() - b.pressStart < threshold) { b.wasPressed = false; return true; } // sub prag = scurt
    b.wasPressed = false;
  }
  return false;
}

// Detecteaza o apasare LUNGA: tinuta apasata peste prag (se declanseaza o singura data)
bool clickLong(Button& b, unsigned long threshold) {
  updateButton(b);
  if (b.wasPressed && b.stableState == LOW && !b.longFired) {  // inca apasat
    if (millis() - b.pressStart >= threshold) { b.longFired = true; return true; } // peste prag = lung
  }
  return false;
}

// Wrappere: NAV scurt/lung = buton fizic SAU buton virtual din web.
// Astfel orice ecran reactioneaza identic la apasare fizica sau web,
// iar dispozitivul si pagina raman in sincron (aceeasi masina de stari).
