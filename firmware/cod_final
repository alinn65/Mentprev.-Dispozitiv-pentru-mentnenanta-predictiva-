// =====================================================
// SETUP - ruleaza o singura data la pornire
// =====================================================
void setup() {
  pinMode(PWR_HOLD_PIN, OUTPUT);
  digitalWrite(PWR_HOLD_PIN, HIGH);   // tinem alimentarea pornita (latch de power)
  pinMode(DISPLAY_PWR_PIN, OUTPUT);
  digitalWrite(DISPLAY_PWR_PIN, LOW); // aprindem backlight-ul (LOW = aprins)

  pinMode(WIFI_LED_PIN, OUTPUT);
  digitalWrite(WIFI_LED_PIN, LOW);    // LED WiFi stins initial
  pinMode(STATUS_LED_PIN, OUTPUT);
  digitalWrite(STATUS_LED_PIN, LOW);  // LED de stare stins initial
  delay(50);

  Serial.begin(115200);               // port serial pentru debug
  pinMode(PWR_BTN_PIN, INPUT_PULLUP); // butoane active LOW
  pinMode(NAV_BTN_PIN, INPUT_PULLUP);
  WiFi.mode(WIFI_OFF);                // pornim cu WiFi oprit (il aprinde utilizatorul)

  // Initializarea perifericelor; fiecare intoarce true/false dupa succes
  bool okDisplay = initDisplay();
  bool okSD      = initSDCard();
  bool okAccel   = initAccelerometer();
  bool okMutex   = initMutex();
  bool okI2S     = initI2S();

  rtcAvailable = initRTC();           // RTC e optional
  if (rtcAvailable) {
    rtcRead(rtcCache);
    lastRtcRead = millis();
    Serial.println("PCF8563 RTC: OK");
  } else {
    Serial.println("PCF8563 RTC: NOT FOUND (optional)");
  }

  if (okSD) prepareNextLogFile();     // pregatim un nume de fisier de rezerva
  if (okSD) loadMachineNames();       // incarcam numele de utilaje salvate

  // Daca un periferic esential lipseste, afisam ecranul de eroare si ne oprim aici
  if (!okDisplay || !okAccel || !okMutex || !okI2S || !okSD) {
    drawInitErrorScreen(okDisplay, okAccel, okSD, okI2S, okMutex);
    while (true) delay(1000);
  }

  clearBuffers();                     // resetam toate datele de calibrare/monitoring
  // Task microfon + FFT pe core 0, prioritate 1
  xTaskCreatePinnedToCore(dspTask, "DSP", 8192, NULL, 1, NULL, 0);
  // Task de esantionare accelerometru la rata fixa. Prioritate 1 
  // pe core 0 impreuna cu DSP 
  xTaskCreatePinnedToCore(accelSamplingTask, "ACC", 6144, NULL, 1, NULL, 0);
  playMenuTransitionIn(true);         // animatie de intrare + logo

  state               = MAIN_MENU;    // pornim in meniul principal
  selectedOption      = MENU_TEST;
  logicalMenuPosition = 0;
  currentAngle        = 0.0f;
}

// =====================================================
// WIFI AP + WEB SERVER
// =====================================================
// Porneste Access Point-ul si serverul web
void wifiStart() {
  if (wifiStarted) return;            // deja pornit
  WiFi.mode(WIFI_AP);
  bool ok;
  if (strlen(WIFI_AP_PASS) >= 8)
    ok = WiFi.softAP(WIFI_AP_SSID, WIFI_AP_PASS, WIFI_AP_CHANNEL); // retea protejata
  else
    ok = WiFi.softAP(WIFI_AP_SSID);   // retea deschisa daca parola e prea scurta
  if (!ok) { Serial.println("WiFi AP: start FAIL"); return; }

  setupWebRoutes();                   // inregistram rutele HTTP
  webServer.begin();
  wifiStarted = true;
  wifiClients = 0;
  Serial.print("WiFi AP pornit. IP: ");
  Serial.println(WiFi.softAPIP());    // de regula 192.168.4.1
}

// Opreste Access Point-ul si serverul web, elibereaza resursele
void wifiStop() {
  if (!wifiStarted) return;
  webServer.stop();
  WiFi.softAPdisconnect(true);
  WiFi.mode(WIFI_OFF);
  wifiStarted = false;
  wifiClients = 0;
  digitalWrite(WIFI_LED_PIN, LOW);    // stingem LED-ul WiFi
  Serial.println("WiFi AP oprit.");
}

// LED: clipeste cand AP pornit dar fara clienti, fix aprins cand are cel putin un client
void updateWifiLed() {
  if (!wifiEnabled || !wifiStarted) {
    digitalWrite(WIFI_LED_PIN, LOW);  // WiFi oprit -> LED stins
    return;
  }
  // actualizeaza numarul de clienti din cand in cand
  if (millis() - lastClientCheck >= CLIENT_CHECK_INTERVAL_MS) {
    lastClientCheck = millis();
    wifiClients = WiFi.softAPgetStationNum();
  }
  if (wifiClients > 0) {
    digitalWrite(WIFI_LED_PIN, HIGH);  // client conectat -> fix aprins
  } else {
    // niciun client -> clipire pentru a semnala "AP activ, in asteptare"
    if (millis() - lastLedBlink >= LED_BLINK_INTERVAL_MS) {
      lastLedBlink = millis();
      ledBlinkState = !ledBlinkState;
      digitalWrite(WIFI_LED_PIN, ledBlinkState ? HIGH : LOW);
    }
  }
}

// LED de stare GPIO48: activ DOAR in monitoring.
// Ritm de clipire in functie de health; aprins fix in standby; stins in rest.
void updateStatusLed() {
  // in afara monitorizarii: LED stins
  if (state != MONITORING) {
    if (statusLedState) { statusLedState = false; digitalWrite(STATUS_LED_PIN, LOW); }
    return;
  }

  // standby (masina oprita): aprins fix
  if (isMachineOff) {
    if (!statusLedState) { statusLedState = true; digitalWrite(STATUS_LED_PIN, HIGH); }
    return;
  }

  // altfel: clipire cu interval dependent de health (mai mic interval = mai rapid)
  unsigned long interval;
  if      (healthScore > 75.0f) interval = 1000;  // OK -> clipire lenta
  else if (healthScore > 45.0f) interval = 400;   // atentie -> clipire medie
  else                          interval = 120;   // alerta -> clipire rapida

  if (millis() - lastStatusBlink >= interval) {
    lastStatusBlink = millis();
    statusLedState = !statusLedState;
    digitalWrite(STATUS_LED_PIN, statusLedState ? HIGH : LOW);
  }
}

